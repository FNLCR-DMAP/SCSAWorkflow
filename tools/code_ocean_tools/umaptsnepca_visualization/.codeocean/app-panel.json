	"parameters": [
		{
			"id": "1020f45873774611",
			"name": "Color By",
			"param_name": "Color_By",
			"description": "Color the points in the plot by either their corresponding feature or annotation.",
			"type": "list",
			"value_type": "string",
			"category": "color_by_parameters",
			"default_value": "Annotation",
			"extra_data": [
				"Annotation",
				"Feature"
			]
		},
		{
			"id": "a51bc35d3a0f41f5",
			"name": "Annotation to Highlight",
			"param_name": "Annotation_to_Highlight",
			"description": "Annotation name in the analysis to use for coloring the cells in the scatter plot based on the cell label. Can't be used with Feature.",
			"type": "text",
			"value_type": "string",
			"category": "color_by_parameters",
			"default_value": "None"
		},
		{
			"id": "a53054371de54c01",
			"name": "Table",
			"param_name": "Table",
			"description": "Source table to perform the visualization. Default is Original, referring to the raw dataset.",
			"type": "text",
			"value_type": "string",
			"category": "color_by_parameters",
			"default_value": "Original"
		},
		{
			"id": "aede8671549f4c81",
			"name": "Feature to Highlight",
			"param_name": "Feature_to_Highlight",
